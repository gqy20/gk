  "student_experiences": [
    {
      "topic": "中传转专业难度和流程",
      "content": "据知乎用户分享：中传转专业硬性要求相对较少，大部分专业对GPA要求不高，部分王牌专业对均分有一点要求，但转入名额较少。需要提前准备，争取一次通过。普通类专业可以转入艺术类专业。",
      "source_type": "知乎",
      "source_url": "https://www.zhihu.com/question/398240676"
    },
    {
      "topic": "中传转专业经验分享",
      "content": "据知乎讨论：小语种以前是单考单招，现在也逐渐允许转专业。转专业前提是要在前期拿到目前所学课程学分并且没有挂科，达标后要参加转入专业考试，考试通过即可转专业。",
      "source_type": "知乎",
      "source_url": "https://www.zhihu.com/question/398240676"
    },
    {
      "topic": "中传文化类转专业难度",
      "content": "据知乎用户反馈：中传转专业硬性要求相对较少（大部分专业对GPA要求不高，部分王牌专业对均分有一点要求），但转入名额也少，所以没有谁能打包票一定能成功。填志愿就是一场博弈，建议自己谨慎选择。",
      "source_type": "知乎",
      "source_url": "https://www.zhihu.com/question/609296325"
    }
  ],
