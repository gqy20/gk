  "transfer_policy": [
    {
      "title": "北京大学本科生转院(系)转专业实施办法(试行)",
      "url": "http://www.dean.pku.edu.cn/web/rules_info.php?id=25",
      "summary": "遵循公平、公开、公正、学生自愿、尊重专业兴趣、兼顾培养规模原则。除教育部规定不得转专业、定向/委培不能转、三年级(含)以上、休学或保留学籍、已达到退学程度的学生外均可申请。每学年办理一次，在第一学年末或第二学年末自主申请。流程：院系公布接收人数→教务部汇总公布→学生网上提交申请→拟转入院系审核→教务部核准公布名单。转专业学生一般转入同年级，确需降级可降级（在校不超过六年）。",
      "attachments": [],
      "publish_date": "",
      "source_department": "北京大学教务部"
    },
    {
      "title": "北京大学校本部2023年转院(系)转专业工作通知",
      "url": "https://dean.pku.edu.cn/web/notice_details.php?id=525",
      "summary": "2023年校本部本科生转院(系)转专业按照《北京大学本科生转院(系)转专业实施办法(试行)》执行。可申请转专业学生为2021级和2022级在学本科生。门户开放时间为4月19日至5月9日。医学部与本部之间各专业可互转，但本部学生不能转入医学部长学制专业。各院系公布具体接收方案和学术要求。",
      "attachments": [],
      "publish_date": "2023-04-17",
      "source_department": "北京大学教务部"
    }
  ],
  "postgrad_recommend": [
    {
      "title": "北京大学推荐优秀应届本科毕业生免试攻读研究生工作实施办法",
      "url": "http://www.dean.pku.edu.cn/web/rules_info.php?id=52",
      "summary": "申请条件：纳入国家普通本科招生计划的应届毕业生（不含专升本、第二学士学位），身心健康，预计能正常毕业并获学士学位，成绩优良，学术研究兴趣浓厚，有较强创新意识和能力，诚实守信，无违法违纪处分，不计划本科毕业后赴境外留学。推免工作由教务部负责推荐环节（每年9月25日前结束），研究生院负责接收录取（每年10月25日前结束）。各院系成立推免工作小组制定选拔标准，学业成绩下游的学生不予推荐。鼓励推荐到外校和科研机构。",
      "attachments": [],
      "publish_date": "",
      "source_department": "北京大学教务部"
    },
    {
      "title": "北京大学2026年接收推荐免试研究生办法（校本部）",
      "url": "https://admission.pku.edu.cn/docs/20250901134327320368.pdf",
      "summary": "申请人基本条件：拥护党的领导，品德良好，遵纪守法，获得所在学校推荐免试资格。申请人须通过北京大学研究生招生网(admission.pku.edu.cn)网上申报，提交申请表、个人陈述、专家推荐信2封、本科成绩单、获奖证书、外语水平证明等材料。各院系自行确定网报和材料接收截止时间。",
      "attachments": [],
      "publish_date": "2025-09-01",
      "source_department": "北京大学研究生院"
    },
