  "student_experiences": [
    {
      "topic": "转专业难度与经验",
      "content": "南京理工大学转专业一般在一年级结束后进行，成绩排名靠前者机会较大，热门专业如计算机、电光竞争较激烈，冷门转热门需绩点较高。具体名额每年不同。",
      "source_type": "知乎",
      "source_url": "https://zhuanlan.zhihu.com/p/1947592071570497607"
    },
    {
      "topic": "保研经验分享",
      "content": "南理工2025届保研率约23%，保研名额1085人。各学院名额分配不同，钱学森学院保研率最高。保研条件包括学业成绩、科研竞赛、综合素质加分等。",
      "source_type": "知乎",
      "source_url": "https://www.gwy.com/baoyan/397108.html"
    }
  ],
