  "student_experiences": [
    {
      "topic": "在校就读体验",
      "content": "钢琴系琴房不够用，琴况无法满足学生正常要求。地理位置优越，位于市中心，汾阳路校区法式风情小洋房令人向往。整体住宿环境较好。",
      "source_type": "知乎",
      "source_url": "https://www.zhihu.com/question/28479764"
    },
    {
      "topic": "考研难度与经验",
      "content": "上音相对公平，老师学富五车且谦虚低调，尊重学生。地理位置优越位于市中心。如果想考，好好努力就有希望。小时候没机会接触音乐，高二才开始学习音乐也能考入。",
      "source_type": "知乎",
      "source_url": "https://www.zhihu.com/question/31616589"
    },
    {
      "topic": "报考攻略",
      "content": "专业成绩合格考生须参加普通高等学校招生全国统一考试。上海音乐学院作为教育部批准的独立设置本科艺术院校，自主划定高考文化课最低录取分数线。",
      "source_type": "知乎专栏",
      "source_url": ""
    }
  ],
