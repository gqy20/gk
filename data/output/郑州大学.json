  "student_experiences": [
    {
      "topic": "郑州大学转专业难度和具体流程",
      "content": "郑大转专业需要在第一学期成绩排名前30%（国际学院前50%，护理学院前15%）才能申请。可以申请3个志愿专业，需要通过转入学院的考核（笔试+面试）。笔试通常考高数等基础课程，面试由学院老师组织。建议提前了解目标专业的招生要求和考核内容。",
      "source_type": "知乎",
      "source_url": "https://www.zhihu.com/question/398237008"
    },
    {
      "topic": "郑州大学转专业经验分享",
      "content": "转专业需要在大一下学期开始申请，提交申请后不可更改。申请前要充分了解拟报专业的人才培养要求、前置课程要求、接收计划人数等。考核通过后可以试读2周，不适应可以退回原专业但当学期不能再申请转专业。",
      "source_type": "知乎",
      "source_url": "https://www.zhihu.com/question/467401622"
    },
    {
      "topic": "郑州大学转专业流程",
      "content": "转专业流程：1.各学院公布接收条件和考核办法；2.学生在线报名（每次可申请3个志愿）；3.资格审核；4.参加学院考核（笔试+面试）；5.公示拟录取名单；6.发放转专业通知书。",
      "source_type": "知乎",
      "source_url": "https://zhuanlan.zhihu.com/p/712290815"
    }
  ],
