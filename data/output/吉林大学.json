  "student_experiences": [
    {
      "topic": "转专业经验",
      "content": "吉大21级学生分享从交通运输转到软件工程的经验。转专业分为试点类和统考类，试点类报名即可转，统考类需笔试加面试。物理类笔试构成为英语40%、高数B36%、物理24%。转专业只有一次机会（大一上报名，大一下考试），绩点需在学院前50%才有资格，最多可报三个平行志愿。",
      "source_type": "知乎",
      "source_url": "https://zhuanlan.zhihu.com/p/568653502"
    },
    {
      "topic": "保研经验",
      "content": "应用数学专业保研经验：成绩排名是硬条件，最好在班级前3名且不能挂科；英语四级必须过，六级尽量高分；有条件参加夏令营获取优秀营员可提前录取；多参加比赛、项目、获得专利、发表论文增加竞争力。",
      "source_type": "知乎",
      "source_url": "https://zhuanlan.zhihu.com/p/455505579"
    },
    {
      "topic": "就读体验",
      "content": "12级校友分享：比较自由的学习氛围，期末考试可突击，但建议不要学他一样得过且过。认识了很多有意思的人，包括各具特点的东北室友、法学院老师、俄语老师等。建议多泡图书馆看书，多参与社团活动。",
      "source_type": "知乎",
      "source_url": "https://www.zhihu.com/question/24398508/answer/441944465"
    },
    {
      "topic": "临床医学保研",
      "content": "吉林大学临床医学保研全攻略，涵盖白求恩第一、第二、第三医院的保研专业方向，包括内科、外科、放射影像、超声、妇产、骨科、检验诊断、麻醉、眼科、儿科等相关专业。",
      "source_type": "B站",
      "source_url": "https://www.bilibili.com/video/BV1Z1jyz7EQk/"
    },
    {
      "topic": "选课建议",
      "content": "大学选修课建议选水课，不要奢望能在课上学到东西，除非确定自己一定会认真听。选课时可以提前向学长学姐请教参考推荐与避坑建议。",
      "source_type": "抖音",
      "source_url": "https://www.douyin.com/note/7397452046275824922"
    }
  ],
