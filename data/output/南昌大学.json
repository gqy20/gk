  "student_experiences": [
    {
      "topic": "南昌大学转专业经验分享（法学）",
      "content": "分享转法学专业经验：先自我介绍，可能被问到有没有看过法律相关的书、有什么理解、为什么对法学感兴趣等。高考分数高一些进的可能性也大一些。",
      "source_type": "知乎",
      "source_url": "https://zhuanlan.zhihu.com/p/379337992"
    },
    {
