  "student_experiences": [
    {
      "topic": "转专业难度与经验",
      "content": "在北京化工大学转专业不算难，绩点3.0以上即可申请。转计算机、自动化等热门专业难度较大（被称为“地狱难度”），转入其他专业如电子、数学、经管等难度一般，转入生化环材相关专业难度极低。绩点是最重要的因素，高等数学、线性代数和英语成绩权重最高。大一学年绩点保持在3.8左右较为稳妥，低于3.4有风险。转计算机类需要通过C语言机考。",
      "source_type": "知乎",
      "source_url": "https://www.zhihu.com/question/398240570"
    },
    {
      "topic": "转专业基本条件",
      "content": "北京化工大学可以转专业，前提条件是学期GPA达到3.0以上。每学期开学都有转专业机会，申请一般都能成功。入学时有一次优秀生考试，全校前5%可进实验班并转专业。转入热门专业竞争较大，转入冷门专业相对容易。",
      "source_type": "百度知道",
      "source_url": "https://zhidao.baidu.com/question/58129808"
    }
  ],
